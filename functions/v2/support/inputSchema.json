{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "required": ["captcha", "formData"],
  "additionalProperties": false,
  "properties": {
    "captcha": {
      "type": "object",
      "required": ["g-recaptcha-response"],
      "properties": {
        "g-recaptcha-response": {
          "type": "string",
          "minLength": 1,
          "maxLength": 10000
        }
      }
    },
    "formData": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "value"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 150
          },
          "value": {
            "type": "string",
            "minLength": 0,
            "maxLength": 100000
          }
        }
      }
    }
  }
}
